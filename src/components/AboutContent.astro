---
// AboutContent Component
import { Image } from "astro:assets";
import bannerImage from "../../public/img/banner-about-me.webp";
import "../styles/carousel.css";
import TranslatedText from "./TranslatedText.astro";
import { translations } from "../i18n/translations";
---

<div class="content-section" id="about-content">
	<div class="name-section">
		<h1>
			<TranslatedText keyStr="about.title" />
		</h1>
		<div class="separador"></div>
	</div>

	<div class="about-content">
		<div class="about-text">
			<svg
				width="42px"
				height="42px"
				viewBox="0 0 24 24"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
				><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
					id="SVGRepo_tracerCarrier"
					stroke-linecap="round"
					stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
					<path
						d="M16 7C16 9.20914 14.2091 11 12 11C9.79086 11 8 9.20914 8 7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7Z"
						stroke="#85eff3"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
					<path
						d="M12 14C8.13401 14 5 17.134 5 21H19C19 17.134 15.866 14 12 14Z"
						stroke="#85eff3"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</g></svg
			>

			<p>
				<TranslatedText keyStr="about.p1" />
			</p>
			<p>
				<TranslatedText keyStr="about.p2" />
			</p>
		</div>

		<div class="skills-section">
			<h2><TranslatedText keyStr="about.skillsTitle" /></h2>

			<div class="skills-grid">
				<!-- Skill 1: Teamwork -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
						></path><circle cx="9" cy="7" r="4"></circle><path
							d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path
							d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
					>
					<span class="skill-name">
						<span class="lang-es">Trabajo en equipo</span>
						<span class="lang-en" style="display:none"
							>Teamwork</span
						>
					</span>
				</div>

				<!-- Skill 2: English -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><circle cx="12" cy="12" r="10"></circle><line
							x1="2"
							y1="12"
							x2="22"
							y2="12"></line><path
							d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
						></path></svg
					>
					<span class="skill-name">
						<span class="lang-es">Inglés nivel B2</span>
						<span class="lang-en" style="display:none"
							>English level B2</span
						>
					</span>
				</div>

				<!-- Skill 3: Continuous Learning -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
						></path><path
							d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
						></path></svg
					>
					<span class="skill-name">
						<span class="lang-es">Aprendizaje continuo</span>
						<span class="lang-en" style="display:none"
							>Continuous learning</span
						>
					</span>
				</div>

				<!-- Skill 4: Problem Solving -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><polygon
							points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
						></polygon></svg
					>
					<span class="skill-name">
						<span class="lang-es">Resolución de problemas</span>
						<span class="lang-en" style="display:none"
							>Problem solving</span
						>
					</span>
				</div>

				<!-- Skill 5: Adaptability -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
						></path></svg
					>
					<span class="skill-name">
						<span class="lang-es">Adaptabilidad</span>
						<span class="lang-en" style="display:none"
							>Adaptability</span
						>
					</span>
				</div>

				<!-- Skill 6: Frontend -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
						></rect><line x1="8" y1="21" x2="16" y2="21"
						></line><line x1="12" y1="17" x2="12" y2="21"
						></line></svg
					>
					<span class="skill-name">
						<span class="lang-es">Automatizaciónes</span>
						<span class="lang-en" style="display:none"
							>Automation</span
						>
					</span>
				</div>

				<!-- Skill 7: Backend -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><rect x="2" y="2" width="20" height="8" rx="2" ry="2"
						></rect><rect
							x="2"
							y="14"
							width="20"
							height="8"
							rx="2"
							ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"
						></line><line x1="6" y1="18" x2="6.01" y2="18"
						></line></svg
					>
					<span class="skill-name">
						<span class="lang-es">Desarrollo Backend</span>
						<span class="lang-en" style="display:none"
							>Backend Development</span
						>
					</span>
				</div>

				<!-- Skill 8: Databases -->
				<div class="skill-card">
					<svg
						class="skill-icon"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path
							d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path
							d="M3 5v14c0 1.66 4 3 9 3s 9-1.34 9-3V5"
						></path></svg
					>
					<span class="skill-name">
						<span class="lang-es">Bases de Datos</span>
						<span class="lang-en" style="display:none"
							>Databases</span
						>
					</span>
				</div>
			</div>
		</div>
	</div>
</div>
