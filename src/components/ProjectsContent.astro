---
// ProjectsContent Component
import { Image } from "astro:assets";
import TranslatedText from "./TranslatedText.astro";
import { translations } from "../i18n/translations";

const proj1Matches = import.meta.glob(
  "../../public/img/proyects/proj1/*.{jpeg,jpg,png,gif,webp}",
  { eager: true },
);
const proj1Images = Object.values(proj1Matches).map(
  (module: any) => module.default,
);

const proj2Matches = import.meta.glob(
  "../../public/img/proyects/proj2/*.{jpeg,jpg,png,gif,webp}",
  { eager: true },
);
const proj2Images = Object.values(proj2Matches).map(
  (module: any) => module.default,
);

const proj3Matches = import.meta.glob(
  "../../public/img/proyects/proj3/*.{jpeg,jpg,png,gif,webp}",
  { eager: true },
);
const proj3Images = Object.values(proj3Matches).map(
  (module: any) => module.default,
);
---

<div class="content-section" id="projects-content">
  <div class="name-section">
    <h1><TranslatedText keyStr="projects.title" /></h1>
    <div class="separador"></div>
  </div>

  <div class="projects-grid">
    <div class="project-card2">
      <div class="project-title">
        <TranslatedText keyStr="projects.proj3.title" />
      </div>
      <div class="project-info-row">
        <div class="project-description-box">
          <p class="description">
            <TranslatedText keyStr="projects.proj3.desc1" />
          </p>
          <br />
          <iframe
            frameborder="0"
            src="https://itch.io/embed/4471766?bg_color=1c1035&fg_color=ffffff&link_color=8b5cf6&border_color=ffffff"
            width="max-content"
            height="167"></iframe>
        </div>
        <div class="project-image-box">
          <div class="carousel-container">
            <div class="carousel-track">
              {
                proj3Images.map((img, index) => (
                  <div class={`carousel-slide ${index === 0 ? "active" : ""}`}>
                    <Image
                      class="carousel-img"
                      src={img}
                      alt={`${translations.projects.proj3.title.es} - Imagen ${index + 1}`}
                      loading={index === 0 ? "eager" : "lazy"}
                      width={600}
                      height={260}
                      format="webp"
                    />
                  </div>
                ))
              }
            </div>
            {
              proj3Images.length > 1 && (
                <>
                  <button
                    class="carousel-btn prev"
                    aria-label="Imagen anterior"
                  >
                    &#10094;
                  </button>
                  <button
                    class="carousel-btn next"
                    aria-label="Siguiente imagen"
                  >
                    &#10095;
                  </button>
                  <div class="carousel-indicators">
                    {proj3Images.map((_, index) => (
                      <button
                        class={`carousel-dot ${index === 0 ? "active" : ""}`}
                        aria-label={`Ir a imagen ${index + 1}`}
                        data-index={index}
                      />
                    ))}
                  </div>
                </>
              )
            }
          </div>
        </div>
      </div>

      <div class="project-tech-row">
        <span class="tech-tag2">Electron</span>
        <span class="tech-tag2">Javascript</span>
        <span class="tech-tag2">Tailwind</span>
        <span class="tech-tag2">Git</span>
      </div>
