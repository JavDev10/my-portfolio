<!-- Image Modal Lightbox -->
<div id="image-modal" class="modal-backdrop">
  <div class="modal-content">
    <button id="modal-close" class="modal-close-btn" aria-label="Cerrar"
      >&times;</button
    >
    <img id="modal-image" src="" alt="Vista ampliada" />
  </div>
</div>

<script>
  const initCarousels = () => {
    const carousels = document.querySelectorAll(".carousel-container");

    carousels.forEach((carousel) => {
      // Prevent double init across Astro View Transitions
      if (carousel.hasAttribute("data-carousel-init")) return;
      carousel.setAttribute("data-carousel-init", "true");

      const track = carousel.querySelector(".carousel-track") as HTMLElement;
      const slides = carousel.querySelectorAll(".carousel-slide");
      const dots = carousel.querySelectorAll(".carousel-dot");
      const prevBtn = carousel.querySelector(".carousel-btn.prev");
      const nextBtn = carousel.querySelector(".carousel-btn.next");

      if (!track || slides.length <= 1) return;

      let currentIndex = 0;
      let slideInterval: number | undefined;

      const updateCarousel = (index: number) => {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;

        currentIndex = index;

        track.style.transform = `translateX(-${currentIndex * 100}%)`;

        slides.forEach((s) => s.classList.remove("active"));
        slides[currentIndex].classList.add("active");

        dots.forEach((d) => d.classList.remove("active"));
        if (dots[currentIndex]) {
          dots[currentIndex].classList.add("active");
        }
      };

      const startSlide = () => {
        // ALWAYS clear previous before creating interval
        clearInterval(slideInterval);
        slideInterval = window.setInterval(() => {
          updateCarousel(currentIndex + 1);
        }, 4500);
      };

      const resetSlide = () => {
        startSlide();
      };

      if (prevBtn) {
        prevBtn.addEventListener("click", () => {
          updateCarousel(currentIndex - 1);
          resetSlide();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener("click", () => {
          updateCarousel(currentIndex + 1);
          resetSlide();
        });
      }

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          updateCarousel(index);
          resetSlide();
        });
      });

      carousel.addEventListener("mouseenter", () =>
        clearInterval(slideInterval),
      );
      carousel.addEventListener("mouseleave", startSlide);

      startSlide();
    });
  };

  // Modal Logic
  const initModal = () => {
    const modal = document.getElementById("image-modal");
    const modalImg = document.getElementById("modal-image") as HTMLImageElement;
    const closeBtn = document.getElementById("modal-close");

    if (!modal || !modalImg || modal.hasAttribute("data-modal-init")) return;
    modal.setAttribute("data-modal-init", "true");

    // Mover el modal directamente al <body> para escapar de contextos de aislamiento de CSS (ej. transforms)
    if (modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }

    const openModal = (src: string) => {
      modalImg.src = src;
      modal.classList.add("show");
      document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
      modal.classList.remove("show");
      document.body.style.overflow = "";
      setTimeout(() => {
        modalImg.src = "";
      }, 300);
    };

    document.querySelectorAll(".carousel-img").forEach((img) => {
      img.addEventListener("click", (e) => {
        const target = e.target as HTMLImageElement;
        openModal(target.src);
      });
    });

    closeBtn?.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.classList.contains("show")) closeModal();
    });
  };

  // Run on initial load and view transitions
  document.addEventListener("DOMContentLoaded", initCarousels);
  document.addEventListener("astro:page-load", initCarousels);
  document.addEventListener("DOMContentLoaded", initModal);
  document.addEventListener("astro:page-load", initModal);
</script>
