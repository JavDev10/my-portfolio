---
// BlogContent Component
import TranslatedText from "./TranslatedText.astro";
import { translations } from "../i18n/translations";
---

<div class="content-section" id="blog-content">
	<div class="name-section">
		<div class="header-row">
			<h1><TranslatedText keyStr="blog.title" /></h1>
			<div class="search-container">
				<div class="search-box">
					<svg
						class="search-icon"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<circle cx="11" cy="11" r="8"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
					<input
						type="text"
						class="search-input lang-es"
						placeholder={translations.blog.searchPlaceholder.es}
						autocomplete="off"
					/>
					<input
						type="text"
						class="search-input lang-en"
						placeholder={translations.blog.searchPlaceholder.en}
						autocomplete="off"
						style="display: none;"
					/>
				</div>
			</div>
		</div>
		<div class="separador"></div>
	</div>

	<div class="blog-content">
		<div class="content-section" id="blog-content">
			<div class="blog-content">
				<div class="blog-posts" id="blog-posts-container">
					<div class="blog-post">
						<h3><TranslatedText keyStr="blog.post5.title" /></h3>
						<p class="post-date">
							<TranslatedText keyStr="blog.post5.date" />
						</p>
						<p class="post-excerpt">
							<TranslatedText keyStr="blog.post5.excerpt" />
						</p>
					</div>
					<div class="blog-post">
						<h3>
							<TranslatedText keyStr="blog.post1.title" />
						</h3>
						<p class="post-date">
							<TranslatedText keyStr="blog.post1.date" />
						</p>
						<p class="post-excerpt">
							<TranslatedText keyStr="blog.post1.excerpt" />
						</p>
						<p class="post-excerpt">
							📘 <TranslatedText keyStr="blog.post1.files" />
							<a
								href="https://docs.google.com/document/d/1Xkkt3ilHWwVpil01hBM6eedNDrRotBmM1br3wH6_Pvk/edit?usp=sharing"
								target="_blank"
								><TranslatedText keyStr="blog.post1.study" /></a
							> - <a
								href="https://drive.google.com/drive/folders/1WPFV7r16wUknlZcaJdSzM1-r9RM_Xxyj?usp=sharing"
								target="_blank"
							>
								<TranslatedText
									keyStr="blog.post1.scripts"
								/></a
							>
						</p>
						<div class="project-tech">
							<span class="tech-tag"
								><TranslatedText
									keyStr="blog.post1.tag1"
								/></span
							>
							<span class="tech-tag">POO</span>
						</div>
					</div>
					<div class="blog-post">
						<h3>
							<TranslatedText keyStr="blog.post2.title" />
						</h3>
						<p class="post-date">
							<TranslatedText keyStr="blog.post1.date" />
						</p>
						<p class="post-excerpt">
							<TranslatedText keyStr="blog.post2.excerpt" />
						</p>
						<p class="post-excerpt">
							📘 <TranslatedText keyStr="blog.post1.files" />
							<a
								href="https://docs.google.com/document/d/1cgfzxkJSfHNLJ724lHKPjZQ7X4W4ry4pBRIApNRTc08/edit?usp=sharing"
								target="_blank"
								><TranslatedText keyStr="blog.post2.study" /></a
							> - <a
								href="https://drive.google.com/drive/folders/1WPFV7r16wUknlZcaJdSzM1-r9RM_Xxyj?usp=sharing"
								target="_blank"
							>
								<TranslatedText
									keyStr="blog.post1.scripts"
								/></a
							>
						</p>
						<div class="project-tech">
							<span class="tech-tag"
								><TranslatedText
									keyStr="blog.post1.tag1"
								/></span
							>
							<span class="tech-tag">POO</span>
						</div>
					</div>
					<div class="blog-post">
						<h3>
							<TranslatedText keyStr="blog.post3.title" />
						</h3>
						<p class="post-date">
							<TranslatedText keyStr="blog.post3.date" />
						</p>
						<p class="post-excerpt">
							<TranslatedText keyStr="blog.post3.excerpt" />
						</p>
						<p class="post-excerpt">
							📘 <TranslatedText keyStr="blog.post1.files" />
							<a
								href="https://docs.google.com/document/d/156l4G15BbLbeypeMWI106T_g8BibuMpJWI4YpMFYZfA/edit?usp=sharing"
								target="_blank"
								><TranslatedText keyStr="blog.post3.study" /></a
							> - <a
								href="https://drive.google.com/drive/folders/1WPFV7r16wUknlZcaJdSzM1-r9RM_Xxyj?usp=sharing"
								target="_blank"
							>
								<TranslatedText
									keyStr="blog.post1.scripts"
								/></a
							>
						</p>
						<div class="project-tech">
							<span class="tech-tag"
								><TranslatedText
									keyStr="blog.post1.tag1"
								/></span
							>
							<span class="tech-tag">POO</span>
						</div>
					</div>
					<div class="blog-post">
						<h3><TranslatedText keyStr="blog.post4.title" /></h3>
						<p class="post-date">
							<TranslatedText keyStr="blog.post4.date" />
						</p>
						<p class="post-excerpt">
							<TranslatedText keyStr="blog.post4.excerpt" />
						</p>
					</div>
				</div>
			</div>
		</div>

		<script>
			document.addEventListener("astro:page-load", () => {
				const searchInputs = document.querySelectorAll(".search-input");
				const postsContainer = document.getElementById(
					"blog-posts-container",
				);

				if (searchInputs.length === 0 || !postsContainer) return;

				const posts = Array.from(
					postsContainer.querySelectorAll(".blog-post"),
				);

				searchInputs.forEach((input) => {
					input.addEventListener("input", (e) => {
						const target = e.target as HTMLInputElement;
						const searchTerm = target.value.toLowerCase().trim();

						// Sync values
						searchInputs.forEach((si) => {
							if (
								si !== target &&
								si instanceof HTMLInputElement
							) {
								si.value = target.value;
							}
						});

						const searchWords = searchTerm
							.split(/\s+/)
							.filter((word) => word.length > 0);

						posts.forEach((post) => {
							const titleElement = post.querySelector("h3");
							if (!titleElement) return;

							// Check text content of visible or invisible elements.
							// textContent gets ALL text. This is acceptable.
							const title =
								titleElement.textContent?.toLowerCase() || "";

							const matches = searchWords.every((word) =>
								title.includes(word),
							);
							const shouldShow = matches || searchTerm === "";

							if (shouldShow) {
								// Show post
								post.classList.remove("hidden");
								requestAnimationFrame(() => {
									post.classList.remove("fading");
								});
							} else {
								// Hide post
								post.classList.add("fading");
								setTimeout(() => {
									if (post.classList.contains("fading")) {
										post.classList.add("hidden");
									}
								}, 400);
							}
						});
					});
				});
			});
		</script>
	</div>
</div>
